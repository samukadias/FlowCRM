// PropostaFlow — schema inicial
// Modela o fluxo: Oportunidade → Tratativa → Verificação → Proposta → Contrato → Atestação/Faturamento

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Pessoas e áreas ────────────────────────────────────────────────

enum Area {
  COMERCIAL // entrada das oportunidades e entrega da proposta ao cliente
  PROPOSTAS // tratativa das oportunidades
  DELIVERY // verificação / validação da tratativa
  CONTRATOS // controle de saúde do contrato
  FATURAMENTO // atestação do serviço prestado
  ADMIN
}

// Perfil dentro da área: analista trabalha o que lhe foi delegado;
// gestor delega e enxerga toda a atividade da equipe.
enum Perfil {
  ANALISTA
  GESTOR
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @default("")
  area         Area
  perfil       Perfil   @default(ANALISTA)
  ativo        Boolean  @default(true) // desativado não faz login; histórico é preservado
  createdAt    DateTime @default(now())

  opportunities Opportunity[]   @relation("CriadoPor")
  events        WorkflowEvent[]
  notificacoes  Notification[]

  propostasAtribuidas  Opportunity[] @relation("ResponsavelProposta")
  contratosAtribuidos  Contract[]    @relation("ResponsavelContrato")
  atestacoesAtribuidas Attestation[] @relation("ResponsavelAtestacao")

  tarefasAtribuidas Tarefa[] @relation("ResponsavelTarefa")
  tarefasCriadas    Tarefa[] @relation("CriadorTarefa")

  espsAtribuidas Esp[]
}

// Lembrete/follow-up. Pode estar ligada a uma proposta (mais comum) ou
// avulsa (ex.: "revisar processo de qualificação").
model Tarefa {
  id          String    @id @default(cuid())
  titulo      String
  descricao   String?
  dataLimite  DateTime?
  concluida   Boolean   @default(false)
  concluidaEm DateTime?
  // Trava de notificação de vencida — mesmo padrão do alerta de estagnação
  alertaVencidaEm DateTime?

  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  responsavelId String
  responsavel   User   @relation("ResponsavelTarefa", fields: [responsavelId], references: [id])
  criadoPorId   String
  criadoPor     User   @relation("CriadorTarefa", fields: [criadoPorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([responsavelId, concluida])
}

// Aviso in-app: criado quando algo entra na fila da área do usuário
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  titulo    String
  link      String
  lida      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, lida])
}

// Cadastrado pelo administrador ou pelo gestor de Propostas
model Cliente {
  id        String   @id @default(cuid())
  nome      String   @unique
  sigla     String   @unique // código curto, ex.: TECHNOVA
  createdAt DateTime @default(now())

  propostas Opportunity[]
  contatos  Contact[]
}

// Interlocutor do cliente — um cliente pode ter vários (financeiro, técnico,
// decisor…); no máximo um é o principal por vez.
model Contact {
  id        String   @id @default(cuid())
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  nome      String
  cargo     String?
  email     String?
  telefone  String?
  principal Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([clienteId])
}

// ─── Fluxo da oportunidade até a proposta ───────────────────────────

enum Stage {
  ENTRADA // registrada pelo Comercial
  EM_TRATATIVA // com a equipe de Propostas
  EM_VERIFICACAO // com o Delivery
  AJUSTES // devolvida pelo Delivery para correção
  PROPOSTA_PRONTA // validada, disponível para o Comercial
  ENVIADA_CLIENTE // proposta entregue ao cliente
  ACEITA // cliente aceitou → gera Contrato
  RECUSADA
  CANCELADA
}

// Classificação obrigatória ao registrar a proposta.
enum TipoProposta {
  ORCAMENTO_ORIENTATIVO // OO
  PROPOSTA_TECNICA // RPT, PO e ESP
}

// Coletado ao mover a proposta para RECUSADA ou CANCELADA — alimenta o
// relatório de motivos de perda.
enum MotivoPerda {
  PRECO
  CONCORRENCIA
  PRAZO
  ESCOPO
  SEM_ORCAMENTO
  SEM_RETORNO
  MUDANCA_PRIORIDADE
  OUTRO
}

model Opportunity {
  id            String   @id @default(cuid())
  codigo        String   @unique // ex: OPP-2026-0001
  clienteId     String
  cliente       Cliente  @relation(fields: [clienteId], references: [id])
  titulo        String
  descricao     String?
  valorEstimado Decimal? @db.Decimal(14, 2)
  // Nullable só para não invalidar propostas registradas antes deste campo
  // existir — obrigatório no formulário de nova proposta.
  tipo          TipoProposta?
  stage         Stage    @default(ENTRADA)
  criadoPorId   String
  criadoPor     User     @relation("CriadoPor", fields: [criadoPorId], references: [id])
  // Responsável atual: delegado pelo gestor da área dona da fila.
  // Zera quando a proposta muda de área.
  responsavelId String?
  responsavel   User?    @relation("ResponsavelProposta", fields: [responsavelId], references: [id])
  // Só preenchido ao mover para RECUSADA ou CANCELADA
  motivoPerda   MotivoPerda?
  // Marca quando o alerta de estagnação foi disparado nesta etapa —
  // evita notificar de novo a cada checagem. Zera a cada mudança de etapa.
  alertaEstagnacaoEm DateTime?
  // Atribuído automaticamente (nunca editado à mão) quando uma proposta do
  // tipo Proposta Técnica entra em tratativa com a Propostas. Formato
  // PD + 2 dígitos do ano + sequência do código — ex.: OPP-2026-0013 → PD260013.
  numeroContratoTecnico String? @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  eventos  WorkflowEvent[]
  contrato Contract?
  tarefas  Tarefa[]
  esps     Esp[]
}

// Classificação da ESP (Especificação dos Serviços). Uma oportunidade do
// tipo Proposta Técnica pode ser desmembrada em até uma ESP de cada tipo.
enum EspTipo {
  ITOI
  ITOD
  APP
}

// Gerada pelo gestor de Propostas ao desmembrar o contrato (PD) de uma
// oportunidade Proposta Técnica. A equipe de Propostas trabalha em cima da
// ESP, não da oportunidade diretamente — a oportunidade só segue para
// Verificação quando todas as suas ESPs estiverem prontas.
model Esp {
  id            String    @id @default(cuid())
  // E + 3 dígitos do ano + 4 dígitos sequenciais — ex.: E0260430
  numero        String    @unique
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])
  tipo          EspTipo
  responsavelId String?
  responsavel   User?     @relation(fields: [responsavelId], references: [id])
  pronta        Boolean   @default(false)
  prontaEm      DateTime?
  // Relatório de projeto técnico (Word) anexado pelo analista responsável —
  // um único documento por ESP, editável enquanto ela não estiver pronta.
  relatorioNome     String?
  relatorioTamanho  Int?
  relatorioUrl      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  itens EspItem[]

  // No máximo uma ESP de cada tipo por oportunidade
  @@unique([opportunityId, tipo])
}

// Catálogo de serviços/produtos de informática vendidos pela empresa —
// mantido pelo ADMIN. Base de preço para os itens da PO nas ESPs.
model ProdutoServico {
  id                  String   @id @default(cuid())
  nome                String   @unique
  unidade             String // ex.: GB, certificado, licença, hora
  valorUnitarioPadrao Decimal  @db.Decimal(14, 2)
  ativo               Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  itens EspItem[]
}

// Linha da PO (Planilha Orçamentária) de uma ESP: quantidade recorrente
// mensal de um produto/serviço do catálogo, pelo período contratual em
// meses. O valor total do contrato para o item é quantidadeMensal ×
// valorUnitario × periodoContratualMeses. valorUnitario pode divergir do
// valorUnitarioPadrao do catálogo (preço negociado). Travado para edição
// assim que a ESP é marcada como pronta.
model EspItem {
  id                     String         @id @default(cuid())
  espId                  String
  esp                    Esp            @relation(fields: [espId], references: [id], onDelete: Cascade)
  produtoId              String
  produto                ProdutoServico @relation(fields: [produtoId], references: [id])
  quantidadeMensal       Decimal        @db.Decimal(12, 2)
  periodoContratualMeses Int
  valorUnitario          Decimal        @db.Decimal(14, 2)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  medicoes Medicao[]

  @@index([espId])
}

// Regra configurável do alerta de estagnação (checagem horária em
// instrumentation.ts): substitui o antigo limiar único fixo por regras que o
// ADMIN cria/edita em /automacoes. `stage: null` funciona como coringa —
// vale para qualquer etapa não terminal sem regra própria.
model AutomationRule {
  id         String   @id @default(cuid())
  nome       String
  stage      Stage?
  diasLimite Int
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum EventType {
  STAGE_CHANGE // mudança de etapa (o evento original do fluxo)
  EMAIL // registro de e-mail trocado com o cliente
  NOTE // anotação interna
  ATTACHMENT // anexo
}

// Trilha de atividade — mudanças de etapa, e-mails, notas e anexos da proposta
model WorkflowEvent {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])

  eventType EventType @default(STAGE_CHANGE)

  // Mudança de etapa (apenas para STAGE_CHANGE)
  deStage    Stage?
  paraStage  Stage? // opcional: e-mail/nota/anexo não têm etapa de destino
  observacao String?

  // E-mail / nota
  subject String?
  content String?

  // Anexo
  fileName String?
  fileSize Int?
  fileUrl  String?

  createdAt DateTime @default(now())

  @@index([opportunityId, createdAt])
}

// ─── Pós-aceite: contrato, saúde e atestação ────────────────────────

enum HealthStatus {
  SAUDAVEL
  ATENCAO
  CRITICO
}

model Contract {
  id             String       @id @default(cuid())
  opportunityId  String       @unique
  opportunity    Opportunity  @relation(fields: [opportunityId], references: [id])
  numero         String       @unique
  inicioVigencia DateTime
  fimVigencia    DateTime?
  valor          Decimal      @db.Decimal(14, 2)
  health         HealthStatus @default(SAUDAVEL)
  responsavelId  String?
  responsavel    User?        @relation("ResponsavelContrato", fields: [responsavelId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  atestacoes Attestation[]
}

enum AttestationStatus {
  PENDENTE // serviço prestado, aguardando confirmação do cliente
  CONFIRMADA_CLIENTE // cliente confirmou → liberada para atestar
  ATESTADA // atestação efetuada, pronta para faturamento
  FATURADA
  CONTESTADA // cliente não confirmou
}

model Attestation {
  id          String            @id @default(cuid())
  contractId  String
  contract    Contract          @relation(fields: [contractId], references: [id])
  competencia   String // ex: "2026-07"
  valor         Decimal           @db.Decimal(14, 2)
  status        AttestationStatus @default(PENDENTE)
  responsavelId String?
  responsavel   User?             @relation("ResponsavelAtestacao", fields: [responsavelId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  medicoes Medicao[]

  @@unique([contractId, competencia])
}

// Apontamento mensal de consumo de um item da PO (EspItem) dentro de uma
// atestação — ex.: "20 GB consumidos em 2026-07". Gerada automaticamente
// (com a quantidade contratada como valor inicial) quando a atestação da
// competência é criada; o Faturamento ajusta para o que o cliente de fato
// consumiu. A soma das medições recalcula Attestation.valor a cada ajuste.
model Medicao {
  id            String      @id @default(cuid())
  attestationId String
  attestation   Attestation @relation(fields: [attestationId], references: [id], onDelete: Cascade)
  espItemId     String
  espItem       EspItem     @relation(fields: [espItemId], references: [id], onDelete: Cascade)
  quantidade    Decimal     @db.Decimal(12, 2)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([attestationId, espItemId])
}